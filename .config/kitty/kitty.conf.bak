# ==========================================
# Theme & Fonts
# ==========================================

include ./theme.conf

# font_family      Hurmit Nerd Font
# font_size        12.0
# adjust_line_height 100%

# BEGIN_KITTY_FONTS
font_family      family="FantasqueSansM Nerd Font Mono"
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS



# ==========================================
# Clipboard & Integration
# ==========================================

copy_on_select yes
# allow_remote_control yes
# listen_on unix:/tmp/kitty
# shell_integration enabled


